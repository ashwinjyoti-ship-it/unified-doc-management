{
  "name": "unified-doc-management",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "web",
    "worker"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:worker\" \"npm run dev:web\"",
    "dev:web": "npm run dev --workspace=web",
    "dev:worker": "npm run dev --workspace=worker",
    "build": "npm run build --workspace=web",
    "build:pages-worker": "npm run build:pages-worker --workspace=worker",
    "deploy": "npm run build --workspace=web && npm run build:pages-worker --workspace=worker && npm run deploy --workspace=worker",
    "db:migrate": "npm run db:migrate --workspace=worker",
    "db:migrate:local": "npm run db:migrate:local --workspace=worker",
    "seed:knowledge-base": "node scripts/seed-knowledge-base.mjs"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
