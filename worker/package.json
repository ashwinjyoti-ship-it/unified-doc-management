{
  "name": "worker",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler pages dev ../web/dist --d1=DB --port=8787",
    "build": "esbuild src/index.ts --bundle --outfile=dist/index.js --format=esm --external:cloudflare:workers",
    "build:pages-worker": "esbuild src/index.ts --bundle --outfile=../web/dist/_worker.js --format=esm --external:cloudflare:workers",
    "pages:project": "wrangler pages project create ash-doc --production-branch=main",
    "d1:create": "wrangler d1 create unified-doc-db --location=wnam",
    "deploy:pages": "npm run build:pages-worker && wrangler pages deploy --project-name=ash-doc --branch=main --commit-dirty=true",
    "deploy:worker": "wrangler deploy --config wrangler.worker.jsonc",
    "deploy": "npm run build:pages-worker && wrangler pages deploy --project-name=ash-doc --branch=main --commit-dirty=true",
    "db:migrate": "wrangler d1 migrations apply unified-doc-db --remote",
    "db:migrate:local": "wrangler d1 migrations apply unified-doc-db --local",
    "types": "wrangler types"
  },
  "dependencies": {
    "hono": "^4.7.5"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250317.0",
    "esbuild": "^0.25.1",
    "typescript": "^5.8.2",
    "wrangler": "^4.5.0"
  }
}
